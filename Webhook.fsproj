<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Webhook</AssemblyName>
    <RootNamespace>Webhook</RootNamespace>
    <WarningLevel>5</WarningLevel>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <!--
    The compilation order matters in F#: a file can only reference
    types and functions defined in files listed above it.
    The dependency flow is: Domain -> Database -> Gateway -> Validation -> Program.
  -->
  <ItemGroup>
    <Compile Include="src/Domain.fs" />
    <Compile Include="src/Database.fs" />
    <Compile Include="src/Gateway.fs" />
    <Compile Include="src/Validation.fs" />
    <Compile Include="src/Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Giraffe" Version="7.0.2" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.0" />
  </ItemGroup>

</Project>
